# =============================================================================
# Teranga PMS — Production Environment Variables
# =============================================================================
# Copy to .env.prod and fill with REAL production values.
# NEVER commit .env.prod to git.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# ── Database ──
DB_PASSWORD=CHANGE_ME_strong_random_password_here

# ── Redis ──
REDIS_PASSWORD=CHANGE_ME_another_strong_password

# ── JWT Secrets (must be different from each other) ──
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32_different

# ── Public URL (your domain, no trailing slash) ──
PUBLIC_URL=https://app.votredomaine.com

# ── CORS (comma-separated allowed origins) ──
ALLOWED_ORIGINS=https://app.votredomaine.com,https://votredomaine.com

# ── FedaPay (subscriptions + payments) ──
FEDAPAY_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
FEDAPAY_SANDBOX=false
FEDAPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── Encryption key for tenant secrets (AES-256-GCM, 32 bytes hex) ──
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ── Optional ──
# LOG_LEVEL=info
# RATE_LIMIT_MAX=100
# BCRYPT_SALT_ROUNDS=12
