# =============================================================================
# Teranga PMS — Test Environment (.env.test)
# Copy this file: cp .env.test.example .env.test
# Generate secrets: openssl rand -hex 32
# =============================================================================

# ── Database ──
DB_PASSWORD=change_me_strong_password

# ── Redis ──
REDIS_PASSWORD=change_me_redis_password

# ── JWT (generate with: openssl rand -hex 32) ──
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me_different

# ── Public URL (your test domain, no trailing slash) ──
PUBLIC_URL=https://demo-teranga.jdidit.cloud

# ── CORS ──
ALLOWED_ORIGINS=https://demo-teranga.jdidit.cloud

# ── FedaPay (sandbox mode for testing) ──
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxx
FEDAPAY_SANDBOX=true
FEDAPAY_WEBHOOK_SECRET=
