// =============================================================================
// Hotel PMS — Prisma Schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPERADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  PENDING_APPROVAL
  LOCKED
  ARCHIVED
}

enum EstablishmentRole {
  OWNER
  DAF
  MANAGER
  MAITRE_HOTEL
  SERVER
  POS
  COOK
  CLEANER
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
  FAMILY
  DELUXE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLEANING
  OUT_OF_ORDER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  MOOV_MONEY
  MIXX_BY_YAS
  FEDAPAY
  OTHER
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER
  WASTE
  RETURN
}

enum BookingSource {
  DIRECT
  BOOKING_COM
  EXPEDIA
  AIRBNB
  CHANNEL_MANAGER
  PHONE
  WALK_IN
}

enum SubscriptionStatus {
  PENDING
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
}

enum ApprovalType {
  EMPLOYEE_CREATION
  RESERVATION_MODIFICATION
  ROOM_CREATION
  STOCK_MOVEMENT
  ARTICLE_CREATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CleaningStatus {
  IN_PROGRESS
  COMPLETED
}

// =============================================================================
// CORE MODELS
// =============================================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  plan      String   @default("basic")
  isActive  Boolean  @default(true) @map("is_active")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users            User[]
  establishments   Establishment[]
  rooms            Room[]
  reservations     Reservation[]
  invoices         Invoice[]
  payments         Payment[]
  articles         Article[]
  categories       ArticleCategory[]
  suppliers        Supplier[]
  stockMovements   StockMovement[]
  refreshTokens    RefreshToken[]
  apiKeys          ApiKey[]
  subscription     Subscription?
  orders           Order[]
  approvalRequests ApprovalRequest[]
  stockAlerts      StockAlert[]
  cleaningSessions CleaningSession[]
  notifications      Notification[]
  channelConnections ChannelConnection[]

  @@map("tenants")
}

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  keyHash   String   @unique @map("key_hash")
  prefix    String
  isActive  Boolean  @default(true) @map("is_active")
  expiresAt DateTime @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  allowedIps Json    @default("[]") @map("allowed_ips")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

model User {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  email               String
  passwordHash        String     @map("password_hash")
  firstName           String     @map("first_name")
  lastName            String     @map("last_name")
  role                UserRole   @default(EMPLOYEE)
  status              UserStatus @default(ACTIVE)
  phone               String?
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lastLoginAt         DateTime?  @map("last_login_at")
  lastActiveAt        DateTime?  @map("last_active_at")
  archivedAt          DateTime?  @map("archived_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  memberships         EstablishmentMember[]
  refreshTokens       RefreshToken[]
  stockMovements      StockMovement[]
  invoicesCreated     Invoice[]             @relation("InvoiceCreator")
  approvedMovements   StockMovement[]       @relation("MovementApprover")
  ordersCreated       Order[]
  approvalRequests    ApprovalRequest[]     @relation("ApprovalRequester")
  approvalReviews     ApprovalRequest[]     @relation("ApprovalReviewer")
  stockAlerts         StockAlert[]
  cleaningSessions    CleaningSession[]
  articlesCreated     Article[]             @relation("ArticleCreator")
  notifications       Notification[]
  deviceTokens        DeviceToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  revoked   Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// =============================================================================
// ESTABLISHMENT & MEMBERSHIP
// =============================================================================

model Establishment {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String
  address    String
  city       String
  country    String
  phone      String?
  email      String?
  website    String?
  starRating Int?     @map("star_rating") @db.SmallInt
  isActive   Boolean  @default(true) @map("is_active")
  timezone   String   @default("UTC")
  currency   String   @default("XOF")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  members          EstablishmentMember[]
  rooms            Room[]
  orders           Order[]
  cleaningSessions CleaningSession[]
  articles         Article[]
  categories       ArticleCategory[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("establishments")
}

model EstablishmentMember {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  establishmentId String            @map("establishment_id")
  role            EstablishmentRole
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  establishment Establishment @relation(fields: [establishmentId], references: [id])

  @@unique([userId, establishmentId])
  @@index([establishmentId, role])
  @@map("establishment_members")
}

// =============================================================================
// ROOMS & RESERVATIONS
// =============================================================================

model Room {
  id              String     @id @default(uuid())
  tenantId        String     @map("tenant_id")
  establishmentId String     @map("establishment_id")
  number          String
  floor           Int?       @db.SmallInt
  type            RoomType
  status          RoomStatus @default(AVAILABLE)
  pricePerNight   Decimal    @map("price_per_night") @db.Decimal(10, 2)
  maxOccupancy    Int        @default(2) @map("max_occupancy")
  amenities       Json       @default("[]")
  description     String?
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  establishment      Establishment       @relation(fields: [establishmentId], references: [id])
  reservations       Reservation[]
  cleaningSessions   CleaningSession[]
  channelConnections ChannelConnection[]

  @@unique([tenantId, establishmentId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("rooms")
}

model Reservation {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  roomId         String            @map("room_id")
  guestName      String            @map("guest_name")
  guestEmail     String?           @map("guest_email")
  guestPhone     String?           @map("guest_phone")
  checkIn        DateTime          @map("check_in") @db.Date
  checkOut       DateTime          @map("check_out") @db.Date
  numberOfGuests Int               @default(1) @map("number_of_guests")
  status         ReservationStatus @default(PENDING)
  source         BookingSource     @default(DIRECT)
  externalRef    String?           @map("external_ref")
  totalPrice     Decimal           @map("total_price") @db.Decimal(10, 2)
  notes          String?
  cancelledAt    DateTime?         @map("cancelled_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  room     Room      @relation(fields: [roomId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@index([tenantId, roomId, checkIn, checkOut])
  @@index([tenantId, status])
  @@index([externalRef])
  @@map("reservations")
}

// =============================================================================
// ORDERS (Restaurant / Bar / Services)
// =============================================================================

model Order {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  establishmentId String      @map("establishment_id")
  createdById     String      @map("created_by_id")
  orderNumber     String      @map("order_number")
  tableNumber     String?     @map("table_number")
  status          OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod? @map("payment_method")
  notes           String?
  totalAmount     Decimal        @default(0) @map("total_amount") @db.Decimal(10, 2)
  invoiceId       String?        @map("invoice_id")
  readyAt         DateTime?   @map("ready_at")
  servedAt        DateTime?   @map("served_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  establishment Establishment @relation(fields: [establishmentId], references: [id])
  createdBy     User          @relation(fields: [createdById], references: [id])
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  items         OrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, establishmentId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  articleId String  @map("article_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  notes     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id])

  @@map("order_items")
}

// =============================================================================
// INVOICES & PAYMENTS
// =============================================================================

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  reservationId String?       @map("reservation_id")
  createdById   String        @map("created_by_id")
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  currency      String        @default("XOF")
  paymentMethod PaymentMethod? @map("payment_method")
  dueDate       DateTime?     @map("due_date") @db.Date
  paidAt        DateTime?     @map("paid_at")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  createdBy   User         @relation("InvoiceCreator", fields: [createdById], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  orders      Order[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  articleId   String? @map("article_id")
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(10, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  invoiceId       String        @map("invoice_id")
  amount          Decimal       @db.Decimal(10, 2)
  method          PaymentMethod
  reference       String?
  transactionUuid String?       @unique @map("transaction_uuid")
  paidAt          DateTime      @default(now()) @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([transactionUuid])
  @@map("payments")
}

// =============================================================================
// STOCK & INVENTORY
// =============================================================================

model ArticleCategory {
  id              String  @id @default(uuid())
  tenantId        String  @map("tenant_id")
  establishmentId String? @map("establishment_id")
  name            String
  parentId        String? @map("parent_id")

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  establishment Establishment?    @relation(fields: [establishmentId], references: [id])
  parent        ArticleCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      ArticleCategory[] @relation("CategoryHierarchy")
  articles      Article[]

  @@unique([tenantId, establishmentId, name])
  @@index([tenantId])
  @@index([establishmentId])
  @@map("article_categories")
}

model Article {
  id              String  @id @default(uuid())
  tenantId        String  @map("tenant_id")
  establishmentId String? @map("establishment_id")
  categoryId      String? @map("category_id")
  name            String
  sku          String?
  description  String?
  imageUrl     String?  @map("image_url")
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  costPrice    Decimal @default(0) @map("cost_price") @db.Decimal(10, 2)
  currentStock Int     @default(0) @map("current_stock")
  minimumStock Int     @default(0) @map("minimum_stock")
  unit         String  @default("pièce")
  isActive     Boolean @default(true) @map("is_active")
  isApproved   Boolean @default(true) @map("is_approved")
  createdById  String? @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  establishment  Establishment?    @relation(fields: [establishmentId], references: [id])
  category       ArticleCategory?  @relation(fields: [categoryId], references: [id])
  createdBy      User?             @relation("ArticleCreator", fields: [createdById], references: [id])
  stockMovements StockMovement[]
  invoiceItems   InvoiceItem[]
  orderItems     OrderItem[]
  stockAlerts    StockAlert[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([establishmentId])
  @@index([tenantId, currentStock])
  @@map("articles")
}

model Supplier {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  stockMovements StockMovement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("suppliers")
}

model StockMovement {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  articleId        String            @map("article_id")
  supplierId       String?           @map("supplier_id")
  performedById    String            @map("performed_by_id")
  type             StockMovementType
  quantity         Int
  unitCost         Decimal?          @map("unit_cost") @db.Decimal(10, 2)
  previousStock    Int               @map("previous_stock")
  newStock         Int               @map("new_stock")
  reason           String?
  requiresApproval Boolean           @default(false) @map("requires_approval")
  approvedById     String?           @map("approved_by_id")
  approvedAt       DateTime?         @map("approved_at")
  createdAt        DateTime          @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  article     Article   @relation(fields: [articleId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  performedBy User      @relation(fields: [performedById], references: [id])
  approvedBy  User?     @relation("MovementApprover", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, articleId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

model StockAlert {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  establishmentId String   @map("establishment_id")
  articleId       String   @map("article_id")
  createdById     String   @map("created_by_id")
  message         String
  isResolved      Boolean  @default(false) @map("is_resolved")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  article   Article @relation(fields: [articleId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([tenantId, establishmentId, isResolved])
  @@map("stock_alerts")
}

// =============================================================================
// APPROVAL WORKFLOW
// =============================================================================

model ApprovalRequest {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  establishmentId String         @map("establishment_id")
  type            ApprovalType
  status          ApprovalStatus @default(PENDING)
  requestedById   String         @map("requested_by_id")
  reviewedById    String?        @map("reviewed_by_id")
  payload         Json
  targetId        String?        @map("target_id")
  reason          String?
  reviewedAt      DateTime?      @map("reviewed_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  requestedBy User   @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewedBy  User?  @relation("ApprovalReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId, establishmentId, status])
  @@map("approval_requests")
}

// =============================================================================
// CLEANING
// =============================================================================

model CleaningSession {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  establishmentId String         @map("establishment_id")
  roomId          String         @map("room_id")
  cleanerId       String         @map("cleaner_id")
  status          CleaningStatus @default(IN_PROGRESS)
  clockInAt       DateTime       @default(now()) @map("clock_in_at")
  clockOutAt      DateTime?      @map("clock_out_at")
  durationMinutes Int?           @map("duration_minutes")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  establishment Establishment @relation(fields: [establishmentId], references: [id])
  room          Room          @relation(fields: [roomId], references: [id])
  cleaner       User          @relation(fields: [cleanerId], references: [id])

  @@index([tenantId, establishmentId, status])
  @@index([roomId, status])
  @@map("cleaning_sessions")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  userId          String   @map("user_id")
  establishmentId String?  @map("establishment_id")
  type            String   // ROOM_CHECKOUT, CLEANING_DONE, ORDER_NEW, ORDER_READY, APPROVAL_NEEDED, APPROVAL_RESULT, STOCK_ALERT
  title           String
  message         String
  data            Json?
  isRead          Boolean  @default(false) @map("is_read")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([tenantId, establishmentId])
  @@map("notifications")
}

// =============================================================================
// CHANNEL SYNC (iCal)
// =============================================================================

model ChannelConnection {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  roomId          String        @map("room_id")
  channel         BookingSource
  exportToken     String        @unique @map("export_token")
  importUrl       String?       @map("import_url")
  isActive        Boolean       @default(true) @map("is_active")
  lastSyncAt      DateTime?     @map("last_sync_at")
  lastSyncStatus  String?       @map("last_sync_status")
  lastSyncError   String?       @map("last_sync_error")
  syncIntervalMin Int           @default(1) @map("sync_interval_min")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  room     Room             @relation(fields: [roomId], references: [id])
  syncLogs ChannelSyncLog[]

  @@unique([tenantId, roomId, channel])
  @@index([tenantId, isActive])
  @@map("channel_connections")
}

model ChannelSyncLog {
  id              String   @id @default(uuid())
  connectionId    String   @map("connection_id")
  direction       String
  eventsFound     Int      @default(0) @map("events_found")
  eventsCreated   Int      @default(0) @map("events_created")
  eventsUpdated   Int      @default(0) @map("events_updated")
  eventsCancelled Int      @default(0) @map("events_cancelled")
  status          String
  errorMessage    String?  @map("error_message")
  durationMs      Int?     @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  connection ChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@map("channel_sync_logs")
}

// =============================================================================
// SUBSCRIPTION & BILLING
// =============================================================================

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(10, 2)
  features     Json     @default("{}")
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  trialDays    Int      @default(14) @map("trial_days")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  tenantId               String             @unique @map("tenant_id")
  planId                 String             @map("plan_id")
  status                 SubscriptionStatus @default(PENDING)
  billingInterval        BillingInterval    @map("billing_interval")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  trialEndsAt            DateTime?          @map("trial_ends_at")
  gracePeriodEndsAt      DateTime?          @map("grace_period_ends_at")
  lastPaymentAt          DateTime?          @map("last_payment_at")
  lastPaymentRef         String?            @map("last_payment_ref")
  lastRenewalLinkSentAt  DateTime?          @map("last_renewal_link_sent_at")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  plan     SubscriptionPlan   @relation(fields: [planId], references: [id])
  payments SubscriptionPayment[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id               String   @id @default(uuid())
  subscriptionId   String   @map("subscription_id")
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("XOF")
  fedapayTxnId     String?  @unique @map("fedapay_txn_id")
  status           String   @default("PENDING")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("subscription_payments")
}

// =============================================================================
// DEVICE TOKENS (FCM Push Notifications)
// =============================================================================

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String   // WEB, ANDROID, IOS
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}
