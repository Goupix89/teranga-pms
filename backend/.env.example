# =============================================================================
# Hotel PMS Backend — Environment Variables
# =============================================================================
# IMPORTANT: Never commit this file with real values to version control.
# Copy to .env and fill in your values.
# =============================================================================

# Database
DATABASE_URL="postgresql://pms_user:your_secure_password@localhost:5432/hotel_pms?sslmode=prefer"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"
JWT_REFRESH_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32_different"

# Token Expiry
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY_DAYS=7

# Server
PORT=4000
NODE_ENV="development"

# CORS
CORS_ORIGIN_PATTERN="https://*.hotelpms.com"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL="info"

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Archival
INACTIVITY_THRESHOLD_DAYS=365

# Stock
STOCK_VARIANCE_THRESHOLD_PERCENT=10
